# Copy to .env.local and fill in (see README). Do not commit .env.local.

# Supabase project ref (subdomain before .supabase.co)
VITE_SUPABASE_PROJECT_REF=your-project-ref

# Project Settings → API → anon public key
VITE_SUPABASE_ANON_KEY=your-anon-key

# Anonymous Auth must be enabled in Supabase Dashboard → Auth → Providers → Anonymous.

# Optional; must match Edge route prefix in supabase/functions/server/index.tsx
# VITE_EDGE_ROUTE_PREFIX=make-server-e35291a5

# Optional; set ENABLE_DEV_ROUTES=true in Supabase function secrets for dev-info and list-models.
